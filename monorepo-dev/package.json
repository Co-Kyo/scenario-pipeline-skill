{
  "name": "skillpack-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "demos"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "clean": "rm -rf packages/*/dist packages/*/tsconfig.tsbuildinfo dist",
    "demo": "npm run start --workspace=@skillpack/demo"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.5.0"
  }
}
