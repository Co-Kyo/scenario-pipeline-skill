{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "${configDir}/dist",
    "rootDir": "${configDir}/src"
  },
  "include": [],
  "references": [
    { "path": "packages/skillpack-types" },
    { "path": "packages/skillpack-common" },
    { "path": "packages/skillpack-validate" },
    { "path": "packages/skillpack-build" }
  ]
}
